root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.{md,yml,yaml}]
indent_size = 2

[*.ps1]
# Windows PowerShell 5.1 が日本語意図コメントを確実に構文解析できるよう BOM を固定する。
charset = utf-8-bom

[*.md]
trim_trailing_whitespace = false
